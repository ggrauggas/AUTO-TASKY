# ── Servidor ──────────────────────────────────────────────
PORT=3000
NODE_ENV=production

# ── Base de datos ─────────────────────────────────────────
# Opción A: connection string completa (Supabase / Railway Postgres)
DATABASE_URL=postgresql://USER:PASSWORD@HOST:PORT/DATABASE

# Opción B: variables individuales (desarrollo local con Docker)
# DB_HOST=localhost
# DB_PORT=5432
# DB_USER=autotasky
# DB_PASSWORD=autotasky123
# DB_NAME=autotasky

# ── JWT ───────────────────────────────────────────────────
JWT_SECRET=cambia-esto-por-un-secreto-seguro-minimo-32-chars
JWT_EXPIRES_IN=8h

# ── Simulación ────────────────────────────────────────────
MAX_ACTIVE_TASKS_PER_USER=1
